import os
import agent

# Open SIP 5060 (TCP/UDP), SIPS 5061 (TCP only) and RTP range (10000-20000).
# NAT-only ports 6060/6061 are managed during configure-module.
agent.assert_exp(agent.add_public_service(os.environ['MODULE_ID'], [
    "5060-5061/tcp",
    "5060/udp",
    "10000-20000/udp"]))
