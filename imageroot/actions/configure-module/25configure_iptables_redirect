# Configure iptables REDIRECT rules for local subnets.
# Redirects traffic from port 5060 to port 6060 for clients in LOCAL_SOURCE_SUBNETS.
# This allows local clients to use the socket without advertised IP.

set -e

# Source environment
source /etc/nethserver/agent.env 2>/dev/null || true

# Check if we're behind NAT and have required variables
if [[ "${BEHIND_NAT}" != "true" ]] || [[ -z "${PRIVATE_IP}" ]]; then
    echo "Not behind NAT or no PRIVATE_IP, skipping iptables redirect rules"
    exit 0
fi

if [[ -z "${LOCAL_SOURCE_SUBNETS}" ]]; then
    echo "No LOCAL_SOURCE_SUBNETS defined, skipping iptables redirect rules"
    exit 0
fi

echo "Configuring iptables redirect rules..."
echo "PRIVATE_IP: ${PRIVATE_IP}"
echo "LOCAL_SOURCE_SUBNETS: ${LOCAL_SOURCE_SUBNETS}"

# Function to add redirect rule if it doesn't exist
add_redirect_rule() {
    local subnet=$1
    local proto=$2
    local src_port=${3:-5060}
    local dst_port=${4:-6060}
    
    # Check if rule exists
    if iptables -t nat -C PREROUTING -s "${subnet}" -d "${PRIVATE_IP}" -p "${proto}" --dport "${src_port}" -j REDIRECT --to-port "${dst_port}" 2>/dev/null; then
        echo "Rule already exists: ${subnet} ${proto} ${src_port} -> ${dst_port}"
    else
        # Add the rule
        if iptables -t nat -A PREROUTING -s "${subnet}" -d "${PRIVATE_IP}" -p "${proto}" --dport "${src_port}" -j REDIRECT --to-port "${dst_port}"; then
            echo "Added rule: ${subnet} ${proto} ${src_port} -> ${dst_port}"
        else
            echo "Failed to add rule: ${subnet} ${proto} ${src_port} -> ${dst_port}" >&2
        fi
    fi
}

# Parse comma-separated subnets and add rules
IFS=',' read -ra SUBNETS <<< "${LOCAL_SOURCE_SUBNETS}"
for subnet in "${SUBNETS[@]}"; do
    subnet=$(echo "${subnet}" | xargs)  # Trim whitespace
    if [[ -n "${subnet}" ]]; then
        echo "Adding redirect rules for subnet: ${subnet}"
        add_redirect_rule "${subnet}" "tcp"
        add_redirect_rule "${subnet}" "udp"
    fi
done

echo "iptables redirect rules configured successfully"
