# Remove iptables REDIRECT rules for local subnets when module is destroyed.

set -e

# Source environment
source /etc/nethserver/agent.env 2>/dev/null || true

# Check if we have required variables
if [[ -z "${PRIVATE_IP}" ]]; then
    echo "No PRIVATE_IP defined, nothing to remove"
    exit 0
fi

echo "Removing iptables redirect rules for PRIVATE_IP: ${PRIVATE_IP}"

# Function to remove redirect rule if it exists
remove_redirect_rule() {
    local subnet=$1
    local proto=$2
    local src_port=${3:-5060}
    local dst_port=${4:-6060}
    
    # Check if rule exists and remove it
    if iptables -t nat -C PREROUTING -s "${subnet}" -d "${PRIVATE_IP}" -p "${proto}" --dport "${src_port}" -j REDIRECT --to-port "${dst_port}" 2>/dev/null; then
        if iptables -t nat -D PREROUTING -s "${subnet}" -d "${PRIVATE_IP}" -p "${proto}" --dport "${src_port}" -j REDIRECT --to-port "${dst_port}"; then
            echo "Removed rule: ${subnet} ${proto} ${src_port} -> ${dst_port}"
        fi
    fi
}

# If LOCAL_SOURCE_SUBNETS is defined, remove those specific rules
if [[ -n "${LOCAL_SOURCE_SUBNETS}" ]]; then
    IFS=',' read -ra SUBNETS <<< "${LOCAL_SOURCE_SUBNETS}"
    for subnet in "${SUBNETS[@]}"; do
        subnet=$(echo "${subnet}" | xargs)  # Trim whitespace
        if [[ -n "${subnet}" ]]; then
            echo "Removing redirect rules for subnet: ${subnet}"
            remove_redirect_rule "${subnet}" "tcp"
            remove_redirect_rule "${subnet}" "udp"
        fi
    done
fi

echo "iptables redirect rules cleanup completed"

